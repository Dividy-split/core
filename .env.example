# ============================================
# Variables d'environnement locales
# ! À ignorer dans Git !
# ============================================

# ========== DATABASE ==========
# Supabase PostgreSQL Connection Strings
# Obtenir depuis:
# 1. Allez sur https://app.supabase.com
# 2. Sélectionnez votre projet
# 3. Settings → Database → Connection string

# URL via le connection pooler (Transaction mode, port 6543)
DATABASE_URL="postgresql://postgres.xxxxx:your-password@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true"

# URL directe sans pooler (port 5432) — utilisée par Prisma pour les migrations
DIRECT_URL="postgresql://postgres.xxxxx:your-password@aws-0-region.supabase.com:5432/postgres"

# ========== BETTER AUTH ==========
# Clé secrète BetterAuth (minimum 32 caractères)
# Générer avec: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BETTER_AUTH_SECRET="your-random-secret-key-32-chars-minimum-xxxxx"

# URL de l'application (dev: http://localhost:3000, prod: https://yourdomain.com)
NEXT_PUBLIC_APP_URL="http://localhost:3000"


# ========== GOOGLE OAUTH ==========
# Configuration Google OAuth
#
# Obtenir depuis:
# 1. https://console.cloud.google.com
# 2. Créer un projet
# 3. APIs & Services → Credentials
# 4. OAuth 2.0 Client ID
# 5. Authorized redirect URIs:
#    - http://localhost:3000/api/auth/callback/google (dev)
#    - https://yourdomain.com/api/auth/callback/google (prod)
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"


# ========== EMAIL SERVICE (RESEND) ==========
# Service d'email pour vérification d'email
#
# Obtenir depuis:
# 1. https://resend.com
# 2. Dashboard → API Keys
# 3. Créer une nouvelle clé API
RESEND_API_KEY="re_xxxxx_your_resend_api_key"
EMAIL_FROM="noreply@dividy.app"
